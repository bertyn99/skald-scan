{
  "name": "skald-scan",
  "private": true,
  "type": "module",
  "exports": {
    "./alchemy": "./alchemy.run.ts"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "deploy:infra": "alchemy deploy --app skald-scan-infra",
    "deploy:apps": "turbo run deploy --ui=stream",
    "deploy": "pnpm deploy:infra && pnpm deploy:apps",
    "destroy:apps": "turbo run destroy --ui=stream",
    "destroy:infra": "alchemy destroy --app skald-scan-infra",
    "destroy": "pnpm destroy:apps && pnpm destroy:infra"
  },
  "devDependencies": {
    "alchemy": "^0.93.12",
    "turbo": "^2.5.6",
    "typescript": "^5.8.3",
    "unstorage": "^1.17.5"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ],
    "catalog": {
      "nuxt": "^3.17.5",
      "@nuxt/ui": "^3.2.0",
      "tailwindcss": "^4.2.2",
      "typescript": "^5.8.3",
      "alchemy": "^0.93.12",
      "@nuxt/eslint": "^1.15.2",
      "eslint": "^10.1.0",
      "vue-tsc": "^3.2.6",
      "@iconify-json/lucide": "^1.2.100",
      "@iconify-json/simple-icons": "^1.2.75"
    }
  }
}
